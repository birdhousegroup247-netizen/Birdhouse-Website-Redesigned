# All of these are used ONLY by the Vercel serverless functions in
# /api — never prefix them with VITE_, since that would ship them
# in the public client bundle. Set the real values in the Vercel
# project's Environment Variables settings (not committed here).

# Cloudinary — Dashboard home page shows Cloud Name, API Key, API
# Secret. Used server-side to generate signed upload requests, so
# uploads stay authenticated without exposing the secret to the browser.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (resend.com) — used to email you when someone submits the
# Contact form, the homepage project inquiry box, or a job application.
RESEND_API_KEY=
# Where submission notifications get sent.
NOTIFY_EMAIL_TO=
# Optional: defaults to Resend's shared test sender if unset. Once you
# verify your own domain in Resend, switch this to something like
# "Birdhouse Group <hello@birdhousegroup.com>".
NOTIFY_EMAIL_FROM=
