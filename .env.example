# All of these are used ONLY by the Vercel serverless functions in
# /api — never prefix them with VITE_, since that would ship them
# in the public client bundle. Set the real values in the Vercel
# project's Environment Variables settings (not committed here).

# Cloudinary — Dashboard home page shows Cloud Name, API Key, API
# Secret. Used server-side to generate signed upload requests, so
# uploads stay authenticated without exposing the secret to the browser.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (Nodemailer) — used to email you when someone submits the
# Contact form, the homepage project inquiry box, or a job application.
# Defaults to Gmail's SMTP server; override SMTP_HOST/SMTP_PORT for a
# different provider.
#
# For Gmail specifically: SMTP_USER is the full Gmail address, and
# SMTP_PASS must be a 16-character App Password, NOT the account's
# regular login password (Google blocks that over SMTP). Generate one
# at https://myaccount.google.com/apppasswords — requires 2-Step
# Verification to be enabled on the account first.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# Where submission notifications get sent.
NOTIFY_EMAIL_TO=
# Optional: defaults to SMTP_USER if unset.
NOTIFY_EMAIL_FROM=
