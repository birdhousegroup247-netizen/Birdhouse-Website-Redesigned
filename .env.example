# Cloudinary unsigned upload config (used for file attachments on the
# project inquiry box and the job application form). Get these from
# the Cloudinary dashboard: Settings > Upload > Upload presets
# (create one with Signing Mode set to "Unsigned").
#
# Never put an API Key/Secret here — this is a client-only static
# site with no backend, so anything in these vars ships in the
# public JS bundle.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
